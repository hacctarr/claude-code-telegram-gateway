{
  "name": "claude-code-telegram-gateway",
  "version": "1.0.6",
  "description": "Steer and mirror Claude Code sessions from your phone via Telegram — auto-created Forum Topics, live desk↔phone mirroring, launchd service.",
  "main": "gateway.js",
  "bin": {
    "claude-tg": "bin/claude-tg.js"
  },
  "scripts": {
    "setup": "node setup.js",
    "start": "node gateway.js",
    "check": "node test/check-telegram.js",
