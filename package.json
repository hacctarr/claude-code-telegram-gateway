    "install-service.sh",
    "uninstall-service.sh",
    "com.claude.telegram-gateway.plist",
    "systemd/claude-gateway.service",
    "config.example.json",
    "README.md",
    "SETUP.md",
    "LICENSE"
  ],
  "dependencies": {},
